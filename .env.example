# =============================================================================
# Dewy Resort Workshop - Workato CLI Configuration (PROJECT ROOT)
# =============================================================================
# This file configures the `wk` (Workato) CLI only. It is SEPARATE from
# app/.env, which configures the Next.js application.
#
# Setup (Unit 0, Step 3):
#   1. Copy this file to `.env`:   cp .env.example .env
#   2. Paste your Workato API token below.
#   3. Run `make workato-login` (reads WORKATO_API_TOKEN from this file).
#
# Get your token from: Workspace Admin -> API Clients
#   https://app.trial.workato.com/members/api/roles
# =============================================================================

WORKATO_API_TOKEN=your_workato_api_token_here
