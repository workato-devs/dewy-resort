# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/app/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/app/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
.env.bak
profiles.env            # File store profiles created by wk cli

# kiro settings with secrets
.kiro/settings/mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/database/*.db
/app/database/*.db
/database/*.db-journal
/app/database/*.db-journal
/database/*.db-shm
/app/database/*.db-shm
/database/*.db-wal
/app/database/*.db-wal

# vendor CLI tools (salesforce, etc.)
bin/
tools/sf-cli/

# workato CLI 
*/.wk/                            # Workato CLI configuration, created by init
**/*.wk
**/*/recipes/.gitignore

# salesforce CLI
.sf/                            # Salesforce CLI configuration
.sfdx/                          # Salesforce DX configuration (legacy)

# runtime files
/var/
/app/var/

# generated files and directories
/bin
/projects
/exclude

# IDE settings
.vscode/

# local development artifacts
_site/
temp-*/